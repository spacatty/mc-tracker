# Required in production. Generate separate values with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
CRON_SECRET=

# SQLite database path. Use persistent storage in production.
SQLITE_PATH=./data/mc-tracker.sqlite

# Optional AI import support.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=MC Tracker
AI_IMPORT_MAX_INPUT_CHARS=20000
AI_IMPORT_MAX_OUTPUT_TOKENS=8000
